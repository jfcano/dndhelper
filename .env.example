## Ejemplo de configuración (no subir .env real)

# Base de datos principal
POSTGRES_URL=postgresql+psycopg://usuario:password@localhost:5432/mi_bd

# Base de datos de tests (aislada)
POSTGRES_TEST_URL=postgresql+psycopg://usuario:password@localhost:5432/mi_bd_test

# JWT (sesiones API; en producción usa un secreto largo y aleatorio)
JWT_SECRET=cambiar-por-secreto-largo-y-aleatorio
# Opcional: minutos de validez del token (por defecto 10080 = 7 días)
# JWT_EXPIRE_MINUTES=10080

# Opcional: usuario administrador (se crea al arrancar la API si no existe; acceso a recursos de todos los usuarios)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=cambiar-esta-contraseña

# Si no hay ADMIN_* ni ningún admin en BD, es obligatoria: autoriza la instalación inicial en /setup (contraseña maestra).
# SETUP_MASTER_PASSWORD=cambiar-por-secreto-de-instalación

# Modelos OpenAI (no son secretos; la clave API se configura en Ajustes en la aplicación)
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large

# Por defecto true: al arrancar uvicorn se lanzan procesos ingest_worker (cola de manuales).
# Pon false si ya ejecutas `python -m backend.scripts.ingest_worker` aparte o usas Docker con servicio dedicado.
# INGEST_WORKER_AUTOSTART=false
# Cuántos subprocesos ingest_worker lanzar (1 por defecto; máximo 32; 0 = ninguno aunque AUTOSTART sea true).
# INGEST_WORKER_COUNT=1

# RAG: colección por defecto solo para scripts CLI (`ingest_pdf` / `ingest_pdfs` sin usuario).
# En la app web, cada usuario tiene su propia colección `rag_u_<uuid_hex>`.
RAG_COLLECTION=rules_5e
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
