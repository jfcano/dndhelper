## Ejemplo de configuración (no subir .env real)

# Base de datos principal
POSTGRES_URL=postgresql+psycopg://usuario:password@localhost:5432/mi_bd

# Base de datos de tests (aislada)
POSTGRES_TEST_URL=postgresql+psycopg://usuario:password@localhost:5432/mi_bd_test

# OpenAI (opcional si configuras la clave en la app: Ajustes → se guarda en BD por LOCAL_OWNER_UUID)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large

# RAG
RAG_COLLECTION=rules_5e
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200

# Owner local (MVP sin autenticación)
LOCAL_OWNER_UUID=bec82f4c-14ae-43aa-8c40-f45d950517f1

